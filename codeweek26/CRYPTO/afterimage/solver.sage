import json
from Crypto.Util.number import long_to_bytes

# 1. Load data dari challenge_data.json yang kamu berikan
n = 
e1 = 3
c1 = 

limb_head = 0xed36bf369c70db4ef234a4def9fdfcc8487119282e554d49de2364e1d82067819b75530e071623dde373011040141fa77f28aa8ee12168fe59fab99262e610d8ad66fc280215da9cb9b196af6cda08378525c02b7f4994baa48fbd59f4622a93
limb_tail_bits = 256

# 2. Rekonstruksi p bagian atas (geser kembali ke posisi asalnya)
p_bar = limb_head << limb_tail_bits

# 3. Definisikan Polynomial Ring di SageMath modulo n
R.<x> = PolynomialRing(Zmod(n))
f = p_bar + x

# 4. Cari root kecil menggunakan metode Coppersmith
# X adalah batas atas dari bit yang tidak diketahui (2^256)
# beta=0.5 karena kita mencari faktor p yang ukurannya sekitar sqrt(n)
print("[*] Mencari sisa bit p dengan Coppersmith...")
roots = f.small_roots(X=2^limb_tail_bits, beta=0.5)

if roots:
    x_val = int(roots[0])
    p = int(p_bar + x_val)
    print(f"[+] Nilai p ditemukan: {p}")
    
    # Validasi faktorisasi
    assert n % p == 0
    q = n // p
    print(f"[+] Nilai q ditemukan: {q}")
    
    # 5. Dekripsi standar RSA menggunakan e1=3
    phi = (p - 1) * (q - 1)
    d1 = pow(e1, -1, phi)
    m = pow(c1, d1, n)
    
    # 6. Bersihkan padding untuk mendapatkan flag
    msg_bytes = long_to_bytes(m)
    print(f"\n[+] Mentah pesan terdekripsi: {msg_bytes}")
    
    if b"|END|" in msg_bytes:
        flag = msg_bytes.split(b"|END|")[-1]
        print(f"\n[!] FLAG: {flag.decode()}")
else:
    print("[-] Root tidak ditemukan. Periksa kembali input data.")
